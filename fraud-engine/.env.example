# Argus Fraud Engine — environment

# HTTP
PORT=4500
NODE_ENV=development

# Service-to-service auth. Argus must send this as a Bearer token on every /v1 call,
# and the engine sends it back to Argus on remediation callbacks. MUST be set and
# strong in production (the engine refuses to boot in prod with the dev default).
FRAUD_ENGINE_API_KEY=fraud_dev_key_change_in_production

# Where the engine calls back to freeze accounts / flag transactions (Argus backend).
ARGUS_BASE_URL=http://localhost:3001
# Bearer the engine presents to Argus's /api/internal/remediation route. In this
# prototype it equals FRAUD_ENGINE_API_KEY on both sides (shared service secret).
ARGUS_SERVICE_KEY=fraud_dev_key_change_in_production

# SQLite store (the engine's own DB — never the Argus DB).
SQLITE_PATH=./data/fraud.db

# When true, severe async decisions automatically call back to Argus to freeze the
# account. When false, they still open a case but take no automated money action.
FRAUD_AUTO_REMEDIATE=true
